<% if (!(typeof user !== 'undefined' && user)) { %>
<section id="pwa-install-banner" class="pwa-banner" style="display:none">
  <button id="pwa-dismiss-btn" class="pwa-btn-close" aria-label="Fechar">✕</button>
  <section class="pwa-banner-icon">
    <img src="/images/logo.png" alt="GymBros" width="52" height="52">
  </section>
  <section class="pwa-banner-text">
    <strong>GymBros no seu celular <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18.5" stroke-width="2.5"/></svg></strong>
    <span>Instale o app e acesse treinos, IA e academias com 1 toque, sem abrir o navegador.</span>
  </section>
  <button id="pwa-install-btn" class="pwa-btn-install">Instalar</button>
</section>
<script>
(function () {
  const dismissed = localStorage.getItem('pwa_dismissed');
  if (dismissed && Date.now() - parseInt(dismissed) < 7 * 24 * 60 * 60 * 1000) return;
  if (window.matchMedia('(display-mode: standalone)').matches) return;

  let deferredPrompt = null;
  const banner     = document.getElementById('pwa-install-banner');
  const btnInstall = document.getElementById('pwa-install-btn');
  const btnDismiss = document.getElementById('pwa-dismiss-btn');

  window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    deferredPrompt = e;
    setTimeout(() => { if (banner) banner.style.display = 'flex'; }, 3000);
  });

  btnInstall?.addEventListener('click', async () => {
    if (!deferredPrompt) return;
    deferredPrompt.prompt();
    const { outcome } = await deferredPrompt.userChoice;
    if (outcome === 'accepted') banner.style.display = 'none';
    deferredPrompt = null;
  });

  btnDismiss?.addEventListener('click', () => {
    banner.style.display = 'none';
    localStorage.setItem('pwa_dismissed', Date.now().toString());
  });

  const isIos        = /iphone|ipad|ipod/i.test(navigator.userAgent);
  const isStandalone = window.matchMedia('(display-mode: standalone)').matches;
  if (isIos && !isStandalone) {
    setTimeout(() => {
      if (banner) {
        banner.style.display = 'flex';
        if (btnInstall) {
          btnInstall.textContent = 'Como instalar';
          btnInstall.addEventListener('click', () => {
            alert('No Safari: toque em compartilhar (□↑) → "Adicionar à Tela de Início"');
          }, { once: true });
        }
      }
    }, 3000);
  }
})();
</script>
<% } %>

<% if (typeof user !== 'undefined' && user) { %>
<section id="push-notif-banner" class="push-notif-banner" style="display:none" aria-label="Ativar notificações">
  <button id="push-notif-close" class="push-notif-close" aria-label="Fechar">✕</button>
  <span class="push-notif-icon">🔔</span>
  <section class="push-notif-text">
    <strong>Notificações de treino</strong>
    Receba alertas de check-in e dicas direto no celular
  </section>
  <button id="push-notif-btn" class="push-notif-action">Ativar</button>
</section>
<script>
(function () {
  if (sessionStorage.getItem('push_banner_dismissed')) return;
  if (!('Notification' in window) || Notification.permission !== 'default') return;
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
  if (window.matchMedia('(display-mode: standalone)').matches === false && window.innerWidth > 768) return;

  var banner  = document.getElementById('push-notif-banner');
  var btnOk   = document.getElementById('push-notif-btn');
  var btnX    = document.getElementById('push-notif-close');

  function dismiss() {
    banner.style.display = 'none';
    sessionStorage.setItem('push_banner_dismissed', '1');
  }

  function urlB64ToUint8(b64) {
    var pad  = '='.repeat((4 - b64.length % 4) % 4);
    var b64c = (b64 + pad).replace(/-/g, '+').replace(/_/g, '/');
    return Uint8Array.from([...atob(b64c)].map(function(c){ return c.charCodeAt(0); }));
  }

  btnOk.addEventListener('click', async function () {
    var perm = await Notification.requestPermission();
    if (perm === 'granted') {
      try {
        var res        = await fetch('/push/vapid-public-key');
        var data       = await res.json();
        var reg        = await navigator.serviceWorker.ready;
        var sub        = await reg.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: urlB64ToUint8(data.publicKey)
        });
        await fetch('/push/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(sub.toJSON())
        });
      } catch(e) {}
    }
    dismiss();
  });

  btnX.addEventListener('click', dismiss);

  setTimeout(function () {
    if (banner) banner.style.display = 'flex';
  }, 4000);
})();
</script>
<% } %>
<script>
(function () {
  const consent = localStorage.getItem('cookie_consent');
  if (consent) return;

  const banner     = document.getElementById('cookie-banner');
  const btnAccept  = document.getElementById('cookie-accept');
  const btnDecline = document.getElementById('cookie-decline');

  if (banner) setTimeout(() => { banner.style.display = 'block'; }, 1500);

  btnAccept?.addEventListener('click', () => {
    localStorage.setItem('cookie_consent', 'accepted');
    banner.style.display = 'none';
  });

  btnDecline?.addEventListener('click', () => {
    localStorage.setItem('cookie_consent', 'essential');
    banner.style.display = 'none';
  });
})();
</script>
