<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<header class="gymbros-header">
        <section class="header-container">
            <section class="menu-icon" id="menuToggle" aria-label="Abrir menu" aria-expanded="false">
                <i class="fas fa-bars" aria-hidden="true"></i>
            </section>

            <section class="logo">
                <a href="/" aria-label="GymBros — Feed">
                    <img src="/images/logo.png" alt="Logo GymBros" width="32" height="32" loading="eager">
                    <span>GymBros</span>
                </a>
            </section>

            <section class="header-right">
                <nav class="lang-selector" id="langSelector" aria-label="Selecionar idioma">
                    <button class="lang-btn" data-lang="pt" title="Português (BR)" aria-label="Mudar para Português">🇧🇷</button>
                    <button class="lang-btn" data-lang="en" title="English (US)"   aria-label="Switch to English">🇺🇸</button>
                    <button class="lang-btn" data-lang="es" title="Español (ES)"   aria-label="Cambiar a Español">🇪🇸</button>
                </nav>

                <a href="/buscar" class="topbar-icon" title="Buscar pessoas" aria-label="Buscar pessoas">
                    <i class="fas fa-search" aria-hidden="true"></i>
                </a>

                <section class="topbar-notif-wrap" style="position:relative">
                    <button class="topbar-notif-btn" id="notifToggle" title="Notificações" aria-label="Notificações" type="button">
                        <i class="fas fa-bell" aria-hidden="true"></i>
                        <span class="notif-badge" id="topbarNotifBadge" style="display:none">0</span>
                    </button>
                    <section class="notif-dropdown" id="notifDropdown" style="display:none">
                        <section class="notif-dropdown-header">
                            <span>Notificações</span>
                            <button class="notif-ler-todas" id="notifLerTodas" type="button">Marcar todas como lidas</button>
                        </section>
                        <section class="notif-dropdown-lista" id="notifLista">
                            <section class="notif-loading"><i class="fas fa-spinner fa-spin"></i></section>
                        </section>
                    </section>
                </section>

                <a href="/u/<%= locals.user && user.username %>" class="topbar-avatar" aria-label="Meu perfil">
                    <img src="<%= locals.user && user.profile_photo || '/images/avatar.png' %>" alt="Avatar" width="32" height="32">
                </a>

                <button id="themeToggle" class="theme-toggle" title="Alternar tema claro/escuro" aria-label="Alternar tema">
                    <i class="fas fa-moon" id="themeIcon" aria-hidden="true"></i>
                </button>
            </section>
        </section>
    </header>
    <script>
    (function () {
        if (localStorage.getItem('gymbros_theme') === 'light') {
            document.body.classList.add('light-mode');
        }

        var header = document.querySelector('.gymbros-header');
        if (header) {
            window.addEventListener('scroll', function () {
                header.classList.toggle('scrolled', window.scrollY > 0);
            }, { passive: true });
        }

        function setThemeIcon(isLight) {
            var icon = document.getElementById('themeIcon');
            if (!icon) return;
            if (isLight) {
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
            } else {
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
            }
        }

        function initThemeToggle() {
            var toggle = document.getElementById('themeToggle');
            if (!toggle) return;
            setThemeIcon(document.body.classList.contains('light-mode'));
            toggle.addEventListener('click', function () {
                var isLight = document.body.classList.toggle('light-mode');
                localStorage.setItem('gymbros_theme', isLight ? 'light' : 'dark');
                var icon = document.getElementById('themeIcon');
                if (icon) {
                    icon.classList.add('theme-icon-spin');
                    setTimeout(function () { setThemeIcon(isLight); }, 180);
                    icon.addEventListener('animationend', function onEnd() {
                        icon.classList.remove('theme-icon-spin');
                        icon.removeEventListener('animationend', onEnd);
                    });
                }
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initThemeToggle);
        } else {
            initThemeToggle();
        }
    })();
    </script>
<script>
(function () {
    document.addEventListener('DOMContentLoaded', function () {
        var btn     = document.getElementById('menuToggle');
        var sidebar = document.querySelector('.aluno-sidebar');
        var overlay = document.getElementById('sidebarOverlay');
        if (!sidebar || !overlay) return;

        var closeBtn = document.createElement('button');
        closeBtn.className = 'aluno-sidebar-close';
        closeBtn.setAttribute('aria-label', 'Fechar menu');
        closeBtn.innerHTML = '<i class="fas fa-times"></i>';
        sidebar.insertBefore(closeBtn, sidebar.firstChild);

        function openMenu()  { sidebar.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
        function closeMenu() { sidebar.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow = ''; }

        if (btn) btn.addEventListener('click', openMenu);
        overlay.addEventListener('click', closeMenu);
        closeBtn.addEventListener('click', closeMenu);
        sidebar.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', closeMenu); });
    });

    function syncLembretesComSW() {
        if (!navigator.serviceWorker || !navigator.serviceWorker.controller) return;
        try {
            var agua = JSON.parse(localStorage.getItem('gymbros_lembrete_agua') || 'null');
            var sono = JSON.parse(localStorage.getItem('gymbros_lembrete_sono') || 'null');
            if (agua) navigator.serviceWorker.controller.postMessage({ type: 'SCHEDULE_AGUA', payload: agua });
            if (sono) navigator.serviceWorker.controller.postMessage({ type: 'SCHEDULE_SONO', payload: sono });
        } catch (e) {}
    }
    if (navigator.serviceWorker) {
        navigator.serviceWorker.ready.then(syncLembretesComSW);
    }
})();
</script>
<style>
@keyframes toastIn { from { opacity:0; transform:translateY(12px) scale(.96); } to { opacity:1; transform:none; } }
@keyframes toastOut { to { opacity:0; transform:translateY(12px) scale(.96); } }
.gymbros-toast {
    position:fixed;bottom:24px;right:24px;
    background:var(--card-bg,#1f1f1f);border:1px solid #C98B1D;
    color:var(--text-color,#fff);padding:14px 18px;border-radius:12px;
    z-index:99999;max-width:320px;min-width:240px;
    animation:toastIn .28s ease;box-shadow:0 6px 24px rgba(0,0,0,.5);
    font-family:inherit;cursor:pointer;
}
.gymbros-toast-title { font-weight:700;color:#C98B1D;margin-bottom:4px;font-size:.875rem; }
.gymbros-toast-body  { font-size:.82rem;opacity:.85;line-height:1.4; }
</style>
<script>
(function(){
    const sse = new EventSource('/api/suporte/notificacoes/stream');
    window.addEventListener('beforeunload', function() { sse.close(); }, { once: true });
    sse.addEventListener('admin_notification', function(e) {
        const d = JSON.parse(e.data);
        const icons = { alerta:'⚠️', promocao:'🎁', informativo:'📢' };
        const t = document.createElement('section');
        t.className = 'gymbros-toast';
        t.innerHTML = `<section class="gymbros-toast-title">${icons[d.tipo]||'🔔'} ${escHtmlToast(d.titulo)}</section><section class="gymbros-toast-body">${escHtmlToast(d.mensagem)}</section>`;
        t.addEventListener('click', () => t.remove());
        document.body.appendChild(t);
        setTimeout(() => { if(t.parentNode) { t.style.animation='toastOut .25s ease forwards'; setTimeout(()=>t.remove(),260); } }, 7000);
    });
    function escHtmlToast(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
})();
</script>
<script src="/js/landscape-report.js" defer></script>
<script src="/js/conquistas.js"></script>
<% if (locals.user) { %>
<script>
(function () {
    const badge      = document.getElementById('topbarNotifBadge');
    const toggle     = document.getElementById('notifToggle');
    const dropdown   = document.getElementById('notifDropdown');
    const lista      = document.getElementById('notifLista');
    const lerTodas   = document.getElementById('notifLerTodas');
    if (!toggle || !dropdown) return;

    function escHtml(s) {
        return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function formatarTempo(iso) {
        const d = new Date(iso);
        const diff = (Date.now() - d) / 1000;
        if (diff < 60) return 'agora';
        if (diff < 3600) return Math.floor(diff / 60) + 'm';
        if (diff < 86400) return Math.floor(diff / 3600) + 'h';
        return Math.floor(diff / 86400) + 'd';
    }

    function atualizarBadge(total) {
        if (total > 0) {
            badge.textContent = total > 99 ? '99+' : total;
            badge.style.display = 'inline-flex';
        } else {
            badge.style.display = 'none';
        }
    }

    async function carregarCount() {
        try {
            const d = await fetch('/api/notificacoes/sociais/count').then(r => r.json());
            atualizarBadge(d.total || 0);
        } catch (_) {}
    }

    async function carregarNotificacoes() {
        lista.innerHTML = '<section class="notif-loading"><i class="fas fa-spinner fa-spin"></i></section>';
        try {
            const d = await fetch('/api/notificacoes/sociais').then(r => r.json());
            if (!d.notificacoes?.length) {
                lista.innerHTML = '<section class="notif-vazio">Nenhuma notificação</section>';
                return;
            }
            lista.innerHTML = d.notificacoes.map(n => `
                <section class="notif-item${n.lida ? '' : ' notif-item--nova'}" data-id="${n.id}">
                    <section class="notif-item-icon notif-icon--${escHtml(n.tipo)}">
                        <i class="fas ${n.tipo === 'solicitacao_amizade' ? 'fa-user-plus' : n.tipo === 'amizade_aceita' ? 'fa-user-check' : 'fa-bell'}"></i>
                    </section>
                    <section class="notif-item-body">
                        <section class="notif-item-titulo">${escHtml(n.titulo)}</section>
                        ${n.mensagem ? `<section class="notif-item-msg">${escHtml(n.mensagem)}</section>` : ''}
                        <section class="notif-item-tempo">${formatarTempo(n.criado_em)}</section>
                    </section>
                    ${!n.lida ? '<span class="notif-dot"></span>' : ''}
                </section>
            `).join('');
        } catch (_) {
            lista.innerHTML = '<section class="notif-vazio">Erro ao carregar</section>';
        }
    }

    toggle.addEventListener('click', e => {
        e.stopPropagation();
        const aberto = dropdown.style.display !== 'none';
        dropdown.style.display = aberto ? 'none' : 'block';
        if (!aberto) carregarNotificacoes();
    });

    document.addEventListener('click', e => {
        if (!dropdown.contains(e.target) && e.target !== toggle) {
            dropdown.style.display = 'none';
        }
    });

    lista.addEventListener('click', async e => {
        const item = e.target.closest('.notif-item--nova');
        if (!item) return;
        const id = item.dataset.id;
        item.classList.remove('notif-item--nova');
        item.querySelector('.notif-dot')?.remove();
        await fetch(`/api/notificacoes/sociais/ler/${id}`, { method: 'POST' }).catch(() => {});
        carregarCount();
    });

    lerTodas.addEventListener('click', async () => {
        await fetch('/api/notificacoes/sociais/ler-todas', { method: 'POST' }).catch(() => {});
        lista.querySelectorAll('.notif-item--nova').forEach(el => {
            el.classList.remove('notif-item--nova');
            el.querySelector('.notif-dot')?.remove();
        });
        atualizarBadge(0);
    });

    // SSE para notificações em tempo real
    const sseSocial = new EventSource('/api/notificacoes/sociais/stream');
    sseSocial.addEventListener('message', e => {
        try {
            const d = JSON.parse(e.data);
            if (d.event === 'notificacao_social') {
                const atual = parseInt(badge.textContent || '0', 10);
                atualizarBadge(isNaN(atual) ? 1 : atual + 1);
                if (dropdown.style.display !== 'none') carregarNotificacoes();
            }
        } catch (_) {}
    });
    window.addEventListener('beforeunload', () => sseSocial.close(), { once: true });

    carregarCount();
})();
</script>
<% } %>
<%- include('./logout-modal') %>
<% if (locals.user && user.status === 'pendente_exclusao') { %>
<section class="banner-exclusao-pendente">
    <i class="fas fa-triangle-exclamation"></i>
    Sua conta está agendada para exclusão em <strong><%= user.diasRestantesExclusao ?? 30 %> dia(s)</strong>.
    <strong>Cancele antes que o prazo expire.</strong>
    <button id="btn-banner-cancelar" onclick="cancelarExclusaoBanner()" class="btn-cancelar-exclusao">
        Cancelar exclusão
    </button>
</section>
<script>
async function cancelarExclusaoBanner() {
    const btn = document.getElementById('btn-banner-cancelar');
    if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Aguarde...'; }
    try {
        const res  = await fetch('/api/conta/cancelar-exclusao', { method: 'POST' });
        const data = await res.json();
        if (data.ok) {
            const t = document.createElement('section');
            t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1f1f1f;border:1px solid #22c55e;color:#fff;padding:14px 22px;border-radius:10px;font-size:.88rem;font-weight:600;z-index:999999;box-shadow:0 8px 32px rgba(0,0,0,.5);max-width:340px;text-align:center;';
            t.textContent = 'Que bom ter você de volta, <%= user.nome.split(" ")[0] %>! 🎉 Sua conta está ativa.';
            document.body.appendChild(t);
            setTimeout(() => location.reload(), 2800);
        } else {
            if (btn) { btn.disabled = false; btn.innerHTML = 'Cancelar exclusão'; }
        }
    } catch (_) {
        if (btn) { btn.disabled = false; btn.innerHTML = 'Cancelar exclusão'; }
    }
}
</script>
<% } %>
