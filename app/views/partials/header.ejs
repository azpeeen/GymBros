<header class="gymbros-header">
        <section class="header-container">
            <section class="menu-icon" id="menuToggle" aria-label="Abrir menu" aria-expanded="false">
                <i class="fas fa-bars" aria-hidden="true"></i>
            </section>

            <section class="logo">
                <a href="/" aria-label="GymBros — Página inicial">
                    <img src="/images/logo.png" alt="Logo GymBros" width="32" height="32" loading="eager">
                    <span>GymBros</span>
                </a>
            </section>

            <section class="header-right">
                <!-- Seletor de idioma -->
                <nav class="lang-selector" id="langSelector" aria-label="Selecionar idioma">
                    <button class="lang-btn" data-lang="pt" title="Português (BR)" aria-label="Mudar para Português">🇧🇷</button>
                    <button class="lang-btn" data-lang="en" title="English (US)"   aria-label="Switch to English">🇺🇸</button>
                    <button class="lang-btn" data-lang="es" title="Español (ES)"   aria-label="Cambiar a Español">🇪🇸</button>
                </nav>

                <% if (typeof user !== 'undefined' && user && !(typeof hideThemeToggle !== 'undefined' && hideThemeToggle)) { %>
                <button id="themeToggle" class="theme-toggle" title="Alternar tema claro/escuro" aria-label="Alternar tema">
                    <i class="fas fa-moon" id="themeIcon" aria-hidden="true"></i>
                </button>
                <% } %>

                <a href="/login" class="user-icon" aria-label="Conta do usuário">
                    <i class="fas fa-user" aria-hidden="true"></i>
                </a>
            </section>
        </section>
    </header>
    <script>
    (function () {
        // ── Aplica tema salvo antes do render ──────────────────────────────
        if (localStorage.getItem('gymbros_theme') === 'light') {
            document.body.classList.add('light-mode');
        }

        // ── Scroll scrolled class ──────────────────────────────────────────
        var header = document.querySelector('.gymbros-header');
        if (header) {
            window.addEventListener('scroll', function () {
                header.classList.toggle('scrolled', window.scrollY > 0);
            }, { passive: true });
        }

        // ── Bootstrap do toggle de tema ────────────────────────────────────
        function setThemeIcon(isLight) {
            var icon = document.getElementById('themeIcon');
            if (!icon) return;
            if (isLight) {
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
            } else {
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
            }
        }

        function initThemeToggle() {
            var toggle = document.getElementById('themeToggle');
            if (!toggle) return;

            // Acerta ícone conforme tema atual
            setThemeIcon(document.body.classList.contains('light-mode'));

            toggle.addEventListener('click', function () {
                var isLight = document.body.classList.toggle('light-mode');
                localStorage.setItem('gymbros_theme', isLight ? 'light' : 'dark');

                var icon = document.getElementById('themeIcon');
                if (icon) {
                    icon.classList.add('theme-icon-spin');
                    // Troca o ícone no ponto de opacidade zero (metade da animação)
                    setTimeout(function () { setThemeIcon(isLight); }, 180);
                    icon.addEventListener('animationend', function onEnd() {
                        icon.classList.remove('theme-icon-spin');
                        icon.removeEventListener('animationend', onEnd);
                    });
                }
            });
        }

        // Funciona tanto se DOM ainda não carregou quanto se já carregou
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initThemeToggle);
        } else {
            initThemeToggle();
        }
    })();
    </script>
<script>
(function () {
    document.addEventListener('DOMContentLoaded', function () {
        var sidebar = document.querySelector('.aluno-sidebar');
        var overlay = document.getElementById('sidebarOverlay');
        if (!sidebar || !overlay) return;
        // Injeta botão X no drawer mobile
        var closeBtn = document.createElement('button');
        closeBtn.className = 'aluno-sidebar-close';
        closeBtn.setAttribute('aria-label', 'Fechar menu');
        closeBtn.innerHTML = '<i class="fas fa-times"></i>';
        sidebar.insertBefore(closeBtn, sidebar.firstChild);
        function closeMenu() {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
            document.body.style.overflow = '';
        }
        closeBtn.addEventListener('click', closeMenu);
    });
})();
</script>
<% if (typeof user !== 'undefined' && user) { %>
<style>
@keyframes toastIn { from { opacity:0; transform:translateY(12px) scale(.96); } to { opacity:1; transform:none; } }
@keyframes toastOut { to { opacity:0; transform:translateY(12px) scale(.96); } }
.gymbros-toast {
    position:fixed;bottom:24px;right:24px;
    background:var(--card-bg,#1f1f1f);border:1px solid #C98B1D;
    color:var(--text-color,#fff);padding:14px 18px;border-radius:12px;
    z-index:99999;max-width:320px;min-width:240px;
    animation:toastIn .28s ease;box-shadow:0 6px 24px rgba(0,0,0,.5);
    font-family:inherit;cursor:pointer;
}
.gymbros-toast-title { font-weight:700;color:#C98B1D;margin-bottom:4px;font-size:.875rem; }
.gymbros-toast-body  { font-size:.82rem;opacity:.85;line-height:1.4; }
</style>
<script>
(function(){
    const sse = new EventSource('/api/suporte/notificacoes/stream');
    window.addEventListener('beforeunload', function() { sse.close(); }, { once: true });
    sse.addEventListener('admin_notification', function(e) {
        const d = JSON.parse(e.data);
        const icons = { alerta:'⚠️', promocao:'🎁', informativo:'📢' };
        const t = document.createElement('section');
        t.className = 'gymbros-toast';
        t.innerHTML = `<section class="gymbros-toast-title">${icons[d.tipo]||'🔔'} ${escHtmlToast(d.titulo)}</section><section class="gymbros-toast-body">${escHtmlToast(d.mensagem)}</section>`;
        t.addEventListener('click', () => t.remove());
        document.body.appendChild(t);
        setTimeout(() => { if(t.parentNode) { t.style.animation='toastOut .25s ease forwards'; setTimeout(()=>t.remove(),260); } }, 7000);
    });
    function escHtmlToast(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
})();
</script>
<% } %>
