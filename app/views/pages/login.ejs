<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/seo') %>

  <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
  <link rel="stylesheet" href="/css/forms.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>

<body class="auth-page auth-login">
  <section class="wrapper">
    <form id="loginForm" class="auth-form">
      <section class="auth-header">
        <p class="auth-kicker">Bem-vindo de volta</p>
        <h1>Login</h1>
        <p class="auth-subtitle">Entre na sua conta para acessar sua área GymBros.</p>
      </section>

      <span class="success-message"></span>

      <section class="input-box">
        <input type="text" id="username" name="username" placeholder="Usuário, CPF ou E-mail">
        <i class='bx bxs-user'></i>
        <span class="error-message" id="username-error"></span>
      </section>

      <section class="input-box">
        <input type="password" id="password" name="password" placeholder="Senha">
        <button type="button" class="toggle-password" data-target="password" title="Mostrar/ocultar senha">
          <i class='bx bx-hide'></i>
        </button>
        <span class="error-message" id="password-error"></span>
      </section>

      <button type="submit" class="btn">Entrar</button>

      <section class="register-link">
        <p>Não tem uma conta? <a href="/register">Registrar</a></p>
      </section>
    </form>

    <aside class="auth-brand-panel">
      <a href="/" class="brand-link" aria-label="Voltar para a página inicial">
        <img src="/images/logo-form.png" class="logo" alt="Logo GymBros">
      </a>

      <section class="brand-copy">
        <span>GYMBROS</span>
        <h2>Seu treino, sua evolução.</h2>
        <p>Controle treinos, acompanhe progresso e use IA para treinar com mais inteligência.</p>
      </section>
    </aside>
  </section>

  <script src="/js/forms.js" type="module"></script>
</body>
</html>