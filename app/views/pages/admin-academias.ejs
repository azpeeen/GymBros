<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Academias — GymBros Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" href="/images/favicon.ico">
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
<section class="admin-wrapper">
    <%- include('../partials/admin-sidebar') %>
    <section class="admin-content">
        <%- include('../partials/admin-topbar') %>
        <main class="admin-main">
            <section class="flex-between mb-16">
                <section>
                    <h1 class="admin-page-title">Academias</h1>
                    <p class="admin-page-subtitle"><%= academias.length %> academia<%= academias.length!==1?'s':'' %> cadastrada<%= academias.length!==1?'s':'' %></p>
                </section>
                <a href="/admin/academias/nova" class="btn btn-gold"><i class="fas fa-plus"></i> Nova Academia</a>
            </section>

            <% if (sucesso) { %>
            <section class="admin-toast" style="position:static;margin-bottom:16px;border-left-color:var(--success)">
                <i class="fas fa-check-circle" style="color:var(--success)"></i> <%= sucesso %>
            </section>
            <% } %>
            <% if (erro) { %>
            <section class="admin-toast" style="position:static;margin-bottom:16px;border-left-color:var(--error)">
                <i class="fas fa-exclamation-circle" style="color:var(--error)"></i> <%= erro %>
            </section>
            <% } %>

            <section class="admin-card">
                <section class="admin-card-body no-pad">
                    <section class="admin-table-wrap">
                        <table class="admin-table">
                            <thead>
                                <tr><th>Nome</th><th>CNPJ</th><th>Cidade</th><th>Responsável</th><th>Plano</th><th>Alunos</th><th>Status</th><th></th></tr>
                            </thead>
                            <tbody>
                            <% if (academias.length === 0) { %>
                            <tr><td colspan="8" style="text-align:center;padding:40px;color:var(--text-muted)">Nenhuma academia cadastrada ainda.</td></tr>
                            <% } %>
                            <% academias.forEach(a => { %>
                            <tr>
                                <td class="fw-600"><%= a.nome %></td>
                                <td class="text-muted"><%= a.cnpj || '—' %></td>
                                <td class="text-muted"><%= [a.cidade, a.estado].filter(Boolean).join('/') || '—' %></td>
                                <td class="text-muted"><%= a.responsavel || '—' %></td>
                                <td>
                                    <% if (a.plano) { %>
                                    <span class="badge badge-gold" style="text-transform:capitalize"><%= a.plano %></span>
                                    <% } else { %><span class="text-muted">—</span><% } %>
                                </td>
                                <td><span class="badge badge-muted"><%= a.totalAlunos %></span></td>
                                <td>
                                    <span class="badge <%=
                                        a.status==='ativa' ? 'badge-success' :
                                        a.status==='pendente' ? 'badge-warning' : 'badge-muted'
                                    %>"><%= a.status %></span>
                                </td>
                                <td><a href="/admin/academias/<%= a.id %>" class="btn btn-outline btn-sm">Ver</a></td>
                            </tr>
                            <% }) %>
                            </tbody>
                        </table>
                    </section>
                </section>
            </section>
        </main>
    </section>
</section>
<script src="/js/admin.js"></script>
</body>
</html>
