<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('../partials/seo') %>
<link rel="icon" type="image/x-icon" href="/images/favicon.ico">
<link rel="stylesheet" href="/css/header.css">
<link rel="stylesheet" href="/css/footer.css">
<link rel="stylesheet" href="/css/area-aluno.css">
<link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
<style>
.eq-hero {
    background: linear-gradient(135deg,#1a1a1a,#111);
    border: 1px solid #2a2a2a; border-radius: 16px;
    padding: 28px; margin-bottom: 24px;
    display: flex; align-items: center; gap: 20px;
}
.eq-hero-icon {
    width: 64px; height: 64px; border-radius: 16px; flex-shrink: 0;
    background: rgba(255,215,0,.12); border: 1px solid rgba(255,215,0,.25);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem; color: #FFD700;
}
.eq-hero-nome { font-size: 1.4rem; font-weight: 800; color: #fff; margin: 0 0 4px; }
.eq-hero-sub  { font-size: .82rem; color: #888; margin: 0; }
.eq-hero-badge {
    margin-left: auto; white-space: nowrap;
    padding: 4px 12px; border-radius: 20px;
    background: rgba(255,215,0,.12); border: 1px solid rgba(255,215,0,.25);
    color: #FFD700; font-size: .72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .05em;
}
.eq-titulo {
    font-size: 1rem; font-weight: 700; color: #FFD700;
    margin: 0 0 16px; display: flex; align-items: center; gap: 8px;
}
.eq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
}
.eq-card {
    background: #1a1a1a; border: 1px solid #2a2a2a;
    border-radius: 14px; overflow: hidden;
    transition: border-color .2s, transform .15s;
}
.eq-card:hover { border-color: rgba(255,215,0,.4); transform: translateY(-2px); }
.eq-card-gif {
    width: 100%; aspect-ratio: 16/9;
    object-fit: cover; display: block; background: #111;
}
.eq-card-placeholder {
    width: 100%; aspect-ratio: 16/9; background: #111;
    display: flex; align-items: center; justify-content: center;
    color: #333; font-size: 2rem;
}
.eq-card-info { padding: 14px 16px; }
.eq-card-nome    { font-size: .9rem; font-weight: 700; color: #fff; margin: 0 0 4px; }
.eq-card-musculo { font-size: .75rem; color: #888; margin: 0; }
.eq-empty { text-align: center; padding: 48px 20px; color: #555; }
.eq-empty i { font-size: 2.5rem; display: block; margin-bottom: 12px; color: #333; }
@media (max-width: 600px) {
    .eq-hero { flex-wrap: wrap; }
    .eq-hero-badge { margin-left: 0; }
    .eq-grid { grid-template-columns: 1fr 1fr; gap: 10px; }
}
</style>
</head>
<body>

<%- include('../partials/header-aluno') %>
<section class="aluno-dashboard">
    <section class="sidebar-overlay" id="sidebarOverlay"></section>
    <%- include('../partials/sidebar-aluno') %>
    <section class="aluno-main">

        <section class="eq-hero">
            <section class="eq-hero-icon"><i class="fas fa-dumbbell"></i></section>
            <section>
                <h1 class="eq-hero-nome"><%= equipamento.nome %></h1>
                <p class="eq-hero-sub">
                    <% if (equipamento.academia_nome) { %>
                    <i class="fas fa-location-dot"></i> <%= equipamento.academia_nome %>
                    <% } %>
                    <% if (equipamento.descricao) { %><% if (equipamento.academia_nome) { %> · <% } %><%= equipamento.descricao %><% } %>
                </p>
            </section>
            <span class="eq-hero-badge"><%= equipamento.grupo_muscular %></span>
        </section>

        <h2 class="eq-titulo">
            <i class="fas fa-play-circle"></i>
            Exercícios neste equipamento (<%= exercicios.length %>)
        </h2>

        <% if (exercicios.length === 0) { %>
        <section class="eq-empty">
            <i class="fas fa-dumbbell"></i>
            <p>Nenhum exercício cadastrado para este equipamento ainda.</p>
        </section>
        <% } else { %>
        <section class="eq-grid">
            <% exercicios.forEach(ex => { %>
            <section class="eq-card">
                <% if (ex.gif_url) { %>
                <img src="<%= ex.gif_url %>" alt="<%= ex.name_pt || ex.name %>"
                     class="eq-card-gif" loading="lazy">
                <% } else { %>
                <section class="eq-card-placeholder">
                    <i class="fas fa-dumbbell"></i>
                </section>
                <% } %>
                <section class="eq-card-info">
                    <p class="eq-card-nome"><%= ex.name_pt || ex.name %></p>
                    <p class="eq-card-musculo">
                        <% if (ex.target_muscle) { %>
                        <i class="fas fa-bullseye"></i> <%= ex.target_muscle %>
                        <% } %>
                    </p>
                </section>
            </section>
            <% }) %>
        </section>
        <% } %>

    </section>
</section>

<%- include('../partials/footer') %>
</body>
</html>
