<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/seo') %>

  <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
  <link rel="stylesheet" href="/css/forms.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>

<body class="auth-page auth-register">
  <section class="wrapper">
    <form id="registerForm" class="auth-form register-form" autocomplete="off">
      <% if (typeof user !== 'undefined' && user) { %>
        <section class="auth-alert">
          <strong>Você está logado como <%= user.nome %>.</strong><br>
          Criar uma nova conta não afetará sua sessão atual.
        </section>
      <% } %>

      <section class="auth-header register-header">
        <section>
          <p class="auth-kicker">Criar conta</p>
          <h1>Registrar</h1>
          <p class="auth-subtitle">Preencha seus dados para acessar a plataforma GymBros.</p>
        </section>

        <a href="/" class="register-logo-link" aria-label="Voltar para a página inicial">
          <img src="/images/logo-form.png" class="register-logo" alt="Logo GymBros">
        </a>
      </section>

      <span class="success-message"></span>

      <section class="form-group-title group-account">
        <span>01</span>
        <p>Dados da conta</p>
      </section>

      <section class="input-box field-nome">
        <input type="text" id="nome" name="nome" placeholder="Nome completo" autocomplete="off">
        <i class='bx bxs-user'></i>
        <span class="error-message" id="nome-error"></span>
      </section>

      <section class="input-box field-cpf">
        <input type="text" id="cpf" name="cpf" placeholder="CPF (somente números)" autocomplete="off">
        <i class='bx bxs-id-card'></i>
        <span class="error-message" id="cpf-error"></span>
      </section>

      <section class="input-box field-email">
        <input type="email" id="email" name="email" placeholder="E-mail" autocomplete="off">
        <i class='bx bx-envelope'></i>
        <span class="error-message" id="email-error"></span>
      </section>

      <section class="input-box field-cep">
        <input type="text" id="cep" name="cep" placeholder="CEP">
        <i class='bx bxs-map'></i>
        <span class="error-message" id="cep-error"></span>
      </section>

      <section class="input-box field-estado">
        <input type="text" id="estado" name="estado" placeholder="UF" readonly maxlength="2">
        <i class='bx bx-flag'></i>
      </section>

      <section class="form-group-title group-address">
        <span>02</span>
        <p>Endereço</p>
      </section>

      <section class="input-box field-logradouro">
        <input type="text" id="logradouro" name="logradouro" placeholder="Rua / Av." readonly>
        <i class='bx bxs-home'></i>
      </section>

      <section class="input-box field-numero">
        <input type="text" id="numero" name="numero" placeholder="Número">
        <i class='bx bx-hash'></i>
      </section>

      <section class="input-box field-bairro">
        <input type="text" id="bairro" name="bairro" placeholder="Bairro" readonly>
        <i class='bx bxs-map-pin'></i>
      </section>

      <section class="input-box field-complemento">
        <input type="text" id="complemento" name="complemento" placeholder="Apto, bloco... (opcional)">
        <i class='bx bx-building'></i>
      </section>

      <section class="input-box field-cidade">
        <input type="text" id="cidade" name="cidade" placeholder="Cidade" readonly>
        <i class='bx bx-city'></i>
      </section>

      <section class="form-group-title group-security">
        <span>03</span>
        <p>Segurança</p>
      </section>

      <section class="input-box field-password">
        <input type="password" id="password" name="password" placeholder="Senha">
        <button type="button" class="toggle-password" data-target="password" title="Mostrar/ocultar senha">
          <i class='bx bx-hide'></i>
        </button>
        <span class="error-message" id="password-error"></span>
      </section>

      <section class="input-box field-confirm-password">
        <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirmar senha">
        <button type="button" class="toggle-password" data-target="confirmPassword" title="Mostrar/ocultar senha">
          <i class='bx bx-hide'></i>
        </button>
        <span class="error-message" id="confirmPassword-error"></span>
      </section>

      <section class="remember-forgot">
        <label>
          <input type="checkbox" id="terms" name="terms">
          <span>Aceito os termos de uso</span>
        </label>
        <span class="error-message" id="terms-error"></span>
      </section>

      <button type="submit" class="btn">Registrar</button>

      <section class="register-link">
        <p>Já tem uma conta? <a href="/login">Entrar</a></p>
      </section>
    </form>
  </section>

  <script>
    window.GYMBROS_ALREADY_LOGGED_IN = <%= (typeof user !== 'undefined' && user) ? 'true' : 'false' %>;
  </script>

  <script>
    document.getElementById('cep').addEventListener('blur', async function () {
      const cep = this.value.replace(/\D/g, '');

      if (cep.length !== 8) return;

      try {
        const response = await fetch(`https://viacep.com.br/ws/${cep}/json/`);
        const data = await response.json();

        if (data.erro) return;

        const logradouro = document.getElementById('logradouro');
        const bairro = document.getElementById('bairro');
        const cidade = document.getElementById('cidade');
        const estado = document.getElementById('estado');

        logradouro.value = data.logradouro || '';
        bairro.value = data.bairro || '';
        cidade.value = data.localidade || '';
        estado.value = data.uf || '';

        [logradouro, bairro, cidade, estado].forEach((el) => {
          el.classList.add('readonly-filled');
        });

        document.getElementById('numero').focus();
      } catch (e) {
        console.error('ViaCEP erro:', e);
      }
    });
  </script>

  <script src="/js/forms.js" type="module"></script>
</body>
</html>