function getLocalDatetime() {
    const now = new Date();
    const data    = now.toLocaleDateString('en-CA');
    const horario = now.toTimeString().slice(0, 8);
    return { data, horario };
}

let _logIdAtual    = null;
let _alimentoAtual = null;
let _itensSessao   = [];
let _fotoFile      = null;
let _searchTimeout = null;
let _tipoAtual     = null;

async function abrirForm(tipo) {
    const modal = document.getElementById('nutri-form-modal');
    // Só resetar contexto se trocar de tipo
    if (modal.dataset.tipo !== tipo) {
        _logIdAtual  = null;
        _itensSessao = [];
    }
    _tipoAtual = tipo;
    modal.dataset.tipo = tipo;
    const labels = { cafe:'Café da manhã', almoco:'Almoço', jantar:'Jantar', lanche:'Lanche', outro:'Outro' };
    document.getElementById('nutri-form-titulo').textContent = labels[tipo] || 'Refeição';
    modal.classList.add('open');
    document.getElementById('nutri-overlay').classList.add('open');
    document.body.style.overflow = 'hidden';
    resetarBusca();
    setTimeout(() => { const el = document.getElementById('nutri-busca-input'); if (el) el.focus(); }, 280);

    if (!_logIdAtual) {
        try {
            const r = await fetch('/api/nutricao/refeicao', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ refeicao_tipo: tipo, ...getLocalDatetime() }),
            });
            const d = await r.json();
            if (d.ok) {
                _logIdAtual = d.log_id;
                const ri = await fetch('/api/nutricao/itens/' + d.log_id);
                const di = await ri.json();
                if (di.itens && di.itens.length) {
                    _itensSessao = di.itens.map(i => ({ ...i, _nome: i.alimento_nome }));
                    atualizarItensSessao();
                }
            }
        } catch (_) {}
    }
}

function fecharForm() {
    document.getElementById('nutri-form-modal').classList.remove('open');
    document.getElementById('nutri-overlay').classList.remove('open');
    document.body.style.overflow = '';
    if (_itensSessao.length > 0) location.reload();
}

function resetarBusca() {
    _alimentoAtual = null;
    const inp = document.getElementById('nutri-busca-input');
    if (inp) inp.value = '';
    document.getElementById('nutri-busca-resultados').innerHTML = '';
    document.getElementById('nutri-alimento-selecionado').style.display = 'none';
    document.getElementById('nutri-busca-wrapper').style.display = 'block';
    document.getElementById('nutri-peso-wrapper').style.display  = 'none';
    atualizarItensSessao();
}

function voltarBusca() {
    _alimentoAtual = null;
    document.getElementById('nutri-alimento-selecionado').style.display = 'none';
    document.getElementById('nutri-busca-wrapper').style.display = 'block';
    // Limpar busca anterior mas manter itens já adicionados na sessão
    const inp = document.getElementById('nutri-busca-input');
    if (inp) inp.value = '';
    document.getElementById('nutri-busca-resultados').innerHTML = '';
    if (inp) inp.focus();
    atualizarItensSessao();
}

let _searchAbortCtrl = null;

// Busca com debounce
document.getElementById('nutri-busca-input').addEventListener('input', function () {
    clearTimeout(_searchTimeout);
    if (_searchAbortCtrl) { _searchAbortCtrl.abort(); _searchAbortCtrl = null; }
    const q = this.value.trim();
    if (q.length < 2) {
        document.getElementById('nutri-busca-resultados').innerHTML = '';
        return;
    }
    document.getElementById('nutri-busca-resultados').innerHTML =
        '<p class="nutri-busca-loading"><i class="fas fa-circle-notch fa-spin"></i> Buscando...</p>';
    _searchTimeout = setTimeout(() => buscarAlimento(q), 400);
});

async function buscarAlimento(q) {
    _searchAbortCtrl = new AbortController();
    const lang = (document.documentElement.lang || 'pt').slice(0, 2);
    try {
        const res  = await fetch(
            '/api/nutricao/buscar?q=' + encodeURIComponent(q) + '&lang=' + lang,
            { signal: _searchAbortCtrl.signal }
        );
        const data = await res.json();
        const el   = document.getElementById('nutri-busca-resultados');
        if (!data.length) {
            el.innerHTML = '<p class="nutri-busca-vazio">Nenhum resultado. Tente outro termo ou use a câmera.</p>';
            return;
        }
        el.innerHTML = data.map((a, i) => `
            <button class="nutri-busca-item" onclick="selecionarAlimento(${i})" type="button">
                <section class="nutri-busca-nome">${esc(a.nome)}</section>
                <section class="nutri-busca-kcal">${Math.round(a.por100g.kcal)} kcal/100g</section>
            </button>
        `).join('');
        el.dataset.resultados = JSON.stringify(data);
    } catch (e) {
        if (e.name === 'AbortError') return;
        document.getElementById('nutri-busca-resultados').innerHTML =
            '<p class="nutri-busca-vazio">Erro na busca.</p>';
    }
}

// ── Alimentos contáveis ───────────────────────────────
const _alimentosContaveis = [
    'egg', 'ovo', 'ovos', 'bread', 'pão', 'pao', 'biscuit', 'bolacha',
    'cookie', 'biscoito', 'cracker', 'wafer', 'tortilla', 'wrap',
    'muffin', 'pancake', 'waffle', 'bagel', 'croissant', 'torrada', 'toast',
];

function isContavel(nomeAlimento) {
    const n = nomeAlimento.toLowerCase();
    return _alimentosContaveis.some(c => n.includes(c));
}

function getPesoUnitario(nome) {
    const n = (nome || '').toLowerCase()
        .normalize('NFD').replace(/[̀-ͯ]/g, '');
    if (n.includes('ovo') || n.includes('egg'))                                                         return 60;
    if (n.includes('pao frances') || n.includes('french bread') || n.includes('pao, frances'))          return 50;
    if (n.includes('pao') || n.includes('bread'))                                                       return 50;
    if (n.includes('bolacha') || n.includes('biscoito') || n.includes('cookie') || n.includes('cracker')) return 10;
    if (n.includes('torrada') || n.includes('toast'))                                                   return 12;
    if (n.includes('omelete'))                                                                          return 60;
    if (n.includes('nugget'))                                                                           return 20;
    if (n.includes('muffin'))                                                                           return 80;
    if (n.includes('bagel'))                                                                            return 100;
    if (n.includes('croissant'))                                                                        return 60;
    return null;
}

function atualizarPreview() {
    if (!_alimentoAtual) return;
    const g = Number(document.getElementById('nutri-quantidade')?.value);
    const el = document.getElementById('nutri-macros-preview');
    if (!el) return;
    if (!g) { el.innerHTML = ''; return; }
    const f = g / 100;
    const a = _alimentoAtual.por100g;
    el.innerHTML = `
        <section class="nutri-preview-grid">
            <section><strong>${Math.round(a.kcal * f)}</strong><small>kcal</small></section>
            <section><strong>${(a.proteina * f).toFixed(1)}g</strong><small>prot</small></section>
            <section><strong>${(a.carbs * f).toFixed(1)}g</strong><small>carbs</small></section>
            <section><strong>${(a.gordura * f).toFixed(1)}g</strong><small>gord</small></section>
        </section>
    `;
}

function renderizarCampoQuantidade() {
    const wrapper     = document.getElementById('nutri-quantidade-wrapper');
    const contavel    = isContavel(_alimentoAtual.nome);
    const pesoUnit    = getPesoUnitario(_alimentoAtual.nome);

    if (contavel) {
        wrapper.innerHTML = `
            <section style="display:flex; gap:10px; margin-bottom:4px;">
                <section style="flex:1">
                    <label class="nutri-label">Unidades</label>
                    <input type="number" id="nutri-unidades" class="nutri-input"
                           placeholder="Ex: 2" min="1" step="1" style="margin-bottom:0">
                </section>
                <section style="flex:1">
                    <label class="nutri-label">ou Gramas (g)</label>
                    <input type="number" id="nutri-quantidade" class="nutri-input"
                           placeholder="Ex: 120" min="1" max="5000" style="margin-bottom:0">
                </section>
            </section>
            <small style="color:#555; font-size:.7rem; display:block; margin-bottom:8px;">
                Preencha unidades${pesoUnit ? ` (1 unid. ≈ ${pesoUnit}g)` : ''} OU gramas — ao menos um é obrigatório
            </small>
        `;
        if (pesoUnit) {
            setTimeout(() => {
                const unEl = document.getElementById('nutri-unidades');
                if (unEl) {
                    unEl.addEventListener('input', function () {
                        const un = Number(this.value);
                        if (un > 0) {
                            const g = Math.round(un * pesoUnit);
                            document.getElementById('nutri-quantidade').value = g;
                            atualizarPreview();
                        }
                    });
                }
            }, 50);
        }
    } else {
        wrapper.innerHTML = `
            <label class="nutri-label">Quantidade (g ou ml) *</label>
            <input type="number" id="nutri-quantidade" class="nutri-input"
                   placeholder="Ex: 300" min="1" max="5000" style="margin-bottom:0">
        `;
    }

    setTimeout(() => {
        const el = document.getElementById('nutri-quantidade');
        if (el) {
            el.addEventListener('input', atualizarPreview);
            el.focus();
        }
    }, 50);
}

function selecionarAlimento(idx) {
    const resultadosRaw = document.getElementById('nutri-busca-resultados').dataset.resultados;
    if (!resultadosRaw) return;
    const resultados = JSON.parse(resultadosRaw);
    if (idx >= 0) _alimentoAtual = resultados[idx];
    if (!_alimentoAtual) return;

    document.getElementById('nutri-busca-wrapper').style.display = 'none';
    document.getElementById('nutri-alimento-selecionado').style.display = 'block';
    document.getElementById('nutri-macros-preview').innerHTML = '';

    const a = _alimentoAtual.por100g;
    document.getElementById('nutri-alimento-info').innerHTML = `
        <section class="nutri-alimento-nome">${esc(_alimentoAtual.nome)}</section>
        <section class="nutri-alimento-meta">
            Por 100g: ${Math.round(a.kcal)} kcal ·
            P: ${a.proteina.toFixed(1)}g ·
            C: ${a.carbs.toFixed(1)}g ·
            G: ${a.gordura.toFixed(1)}g
        </section>
    `;
    renderizarCampoQuantidade();
}

// Adicionar item
document.getElementById('nutri-add-item-btn').addEventListener('click', async () => {
    const inputUnidades = document.getElementById('nutri-unidades');
    const inputGramas   = document.getElementById('nutri-quantidade');
    const tipo = document.getElementById('nutri-form-modal').dataset.tipo;

    let g = Number(inputGramas?.value);

    if ((!g || g <= 0) && inputUnidades) {
        const unidades = Number(inputUnidades.value);
        if (unidades > 0) {
            const pesoUnit = getPesoUnitario(_alimentoAtual?.nome || '');
            if (pesoUnit) {
                g = unidades * pesoUnit;
                if (inputGramas) inputGramas.value = g;
            } else {
                alert('Para este alimento, informe o peso em gramas.');
                inputGramas?.focus();
                return;
            }
        }
    }

    if (!g || g <= 0) { alert('Informe a quantidade em gramas ou o número de unidades.'); return; }
    if (!_alimentoAtual) return;

    const btn = document.getElementById('nutri-add-item-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Salvando...';

    try {
        if (!_logIdAtual) {
            const r = await fetch('/api/nutricao/refeicao', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ refeicao_tipo: tipo, ...getLocalDatetime() }),
            });
            const d = await r.json();
            if (!d.ok) { alert('Erro ao criar refeição.'); return; }
            _logIdAtual = d.log_id;
        }

        const a = _alimentoAtual.por100g;
        const res = await fetch('/api/nutricao/item', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                log_id:        _logIdAtual,
                alimento_nome: _alimentoAtual.nome,
                quantidade_g:  g,
                kcal_100g:     a.kcal,
                proteina_100g: a.proteina,
                carbs_100g:    a.carbs,
                gordura_100g:  a.gordura,
                fibra_100g:    a.fibra,
                fonte:         _alimentoAtual.fonte,
                fonte_id:      _alimentoAtual.id,
            }),
        });
        const data = await res.json();
        if (!data.ok) { alert(data.erro || 'Erro ao adicionar item.'); return; }

        const f = g / 100;
        _itensSessao.push({ ...data.item, _nome: _alimentoAtual.nome });
        atualizarTotais(
            Math.round(a.kcal * f),
            parseFloat((a.proteina * f).toFixed(1)),
            parseFloat((a.carbs   * f).toFixed(1)),
            parseFloat((a.gordura * f).toFixed(1)),
            parseFloat((a.fibra   * f).toFixed(1))
        );
        atualizarKcalTipo(tipo, Math.round(a.kcal * f));
        atualizarItensSessao();
        voltarBusca();
    } catch (_) {
        alert('Erro de rede.');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-plus"></i> Adicionar à refeição';
    }
});

function atualizarItensSessao() {
    const wrapper = document.getElementById('nutri-itens-sessao');
    const lista   = document.getElementById('nutri-itens-lista');
    const totalEl = document.getElementById('nutri-itens-total');
    if (!_itensSessao.length) { wrapper.style.display = 'none'; return; }
    wrapper.style.display = 'block';
    lista.innerHTML = _itensSessao.map(i => `
        <section class="nutri-item-sessao">
            <section class="nutri-item-sessao-info">
                <span class="nutri-item-sessao-nome">${esc(i._nome || i.alimento_nome)}</span>
                <span class="nutri-item-sessao-qtd">${i.quantidade_g}g</span>
            </section>
            <span class="nutri-item-sessao-kcal">${Math.round(i.kcal)} kcal · P:${Number(i.proteina_g).toFixed(0)}g</span>
        </section>
    `).join('');
    const totKcal = _itensSessao.reduce((a, i) => a + Number(i.kcal), 0);
    const totProt = _itensSessao.reduce((a, i) => a + Number(i.proteina_g), 0);
    totalEl.innerHTML = `Total: <strong>${Math.round(totKcal)} kcal</strong> · P: ${totProt.toFixed(1)}g`;
}

