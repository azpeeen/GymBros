document.getElementById('nutri-analisar-btn').addEventListener('click', async () => {
    const peso = Number(document.getElementById('nutri-peso-alimento').value);
    if (!peso || !_fotoFile) { alert('Informe o peso do alimento.'); return; }
    const btn = document.getElementById('nutri-analisar-btn');
    btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i>';
    btn.disabled  = true;
    try {
        const fd = new FormData();
        fd.append('foto', _fotoFile);
        fd.append('peso_g', peso);
        const res  = await fetch('/api/nutricao/foto', { method: 'POST', body: fd });
        const data = await res.json();
        if (!data.ok) { alert(data.erro || 'Não foi possível analisar.'); return; }
        const a = data.analise;
        _alimentoAtual = {
            nome:    a.refeicao,
            fonte:   'ia',
            id:      null,
            por100g: {
                kcal:     (a.kcal        / peso) * 100,
                proteina: (a.proteina_g  / peso) * 100,
                carbs:    (a.carbs_g     / peso) * 100,
                gordura:  (a.gordura_g   / peso) * 100,
                fibra:    ((a.fibra_g || 0) / peso) * 100,
            },
        };
        document.getElementById('nutri-peso-wrapper').style.display = 'none';
        selecionarAlimento(-1);
        // Preencher gramas com o peso informado
        setTimeout(() => {
            const qEl = document.getElementById('nutri-quantidade');
            if (qEl) { qEl.value = peso; atualizarPreview(); }
        }, 80);
    } catch (_) { alert('Erro ao analisar.'); }
    finally {
        btn.innerHTML = '<i class="fas fa-search"></i> Analisar';
        btn.disabled  = false;
    }
});

// ═══════════════════════════════════════════════════════
// HISTÓRICO
// ═══════════════════════════════════════════════════════

async function carregarHistorico(page) {
    page = page || 1;
    const res  = await fetch(`/api/nutricao/historico?page=${page}`).catch(() => null);
    if (!res) return;
    const data = await res.json().catch(() => null);
    if (!data) return;
    const el   = document.getElementById('nutri-historico-lista');
    const pag  = document.getElementById('nutri-historico-paginacao');
    if (!el) return;

    if (!data.dias || !data.dias.length) {
        el.innerHTML = '<p class="nutri-empty" style="padding:20px;text-align:center;color:#555;font-size:.85rem">Nenhum registro ainda.</p>';
        return;
    }

    const tipoLabel = { cafe:'Café', almoco:'Almoço', jantar:'Jantar', lanche:'Lanche', outro:'Outro' };

    el.innerHTML = data.dias.map(dia => `
        <section class="nutri-hist-dia">
            <section class="nutri-hist-dia-header">
                <span class="nutri-hist-data">${formatarDataHist(dia.data)}</span>
                <span class="nutri-hist-total">${Math.round(dia.total_kcal)} kcal · P: ${Number(dia.total_prot).toFixed(0)}g</span>
            </section>
            ${(dia.logs || []).map(log => `
            <section class="nutri-hist-refeicao">
                <span class="nutri-hist-tipo">${tipoLabel[log.refeicao_tipo] || 'Refeição'}</span>
                <span class="nutri-hist-kcal">${Math.round(log.kcal)} kcal</span>
                <section class="nutri-hist-itens">
                    ${(log.itens || []).filter(i => i.id).map(i =>
                        `<span class="nutri-hist-item">${esc(i.alimento_nome || i.nome || '—')} ${i.quantidade_g}g</span>`
                    ).join('')}
                </section>
            </section>`).join('')}
        </section>
    `).join('');

    if (pag) {
        pag.innerHTML = '';
        if (data.page > 1) {
            const btn = document.createElement('button');
            btn.className   = 'nutri-pag-btn';
            btn.textContent = '← Mais recentes';
            btn.type        = 'button';
            btn.onclick     = () => carregarHistorico(data.page - 1);
            pag.appendChild(btn);
        }
        if (data.page < data.totalPages) {
            const btn = document.createElement('button');
            btn.className   = 'nutri-pag-btn';
            btn.textContent = 'Mais antigos →';
            btn.type        = 'button';
            btn.onclick     = () => carregarHistorico(data.page + 1);
            pag.appendChild(btn);
        }
    }
}

function formatarDataHist(val) {
    if (!val) return '—';
    const s = String(val).trim().slice(0, 10);
    if (/^\d{4}-\d{2}-\d{2}$/.test(s)) {
        const [y, m, d] = s.split('-');
        return new Date(Number(y), Number(m) - 1, Number(d))
            .toLocaleDateString('pt-BR', { weekday: 'short', day: '2-digit', month: 'short' });
    }
    return s;
}

// ── Init ──────────────────────────────────────────────
(function init() {
    <%
    const tipoKeys = ['cafe','almoco','jantar','lanche','outro'];
    tipoKeys.forEach(k => {
        const sum = registrosHoje.filter(r => r.refeicao_tipo === k).reduce((a,r) => a + (Number(r.kcal)||0), 0);
    %>
    _kcalPorTipo['<%= k %>'] = <%= sum %>;
    <% }) %>

    const volSalvo = localStorage.getItem(AGUA_VOL_KEY);
    if (volSalvo) {
        const sel = document.getElementById('aguaVolumeSelect');
        const opcoes = Array.from(sel.options).map(o => parseInt(o.value));
        const maisPerto = opcoes.reduce((a, b) =>
            Math.abs(b - parseInt(volSalvo)) < Math.abs(a - parseInt(volSalvo)) ? b : a
        );
        sel.value = maisPerto;
    }
    updateAguaUI();
    gerarInsight();
    atualizarRing(_totais.kcal);
    carregarHistorico(1);
})();
</script>
