// ── Autocomplete de aparelhos ─────────────────────────────────────────────────
(function initAutocompletAparelho() {
    const inputAparelho = document.getElementById('eq-nome-input');
    const sugestoesEl   = document.getElementById('eq-nome-sugestoes');

    inputAparelho.addEventListener('input', () => {
        const q = inputAparelho.value.toLowerCase().trim();
        sugestoesEl.innerHTML = '';
        if (q.length < 2) { sugestoesEl.style.display = 'none'; return; }

        const matches = APARELHOS_MAP.filter(a => a.nome.toLowerCase().includes(q)).slice(0, 8);
        if (!matches.length) { sugestoesEl.style.display = 'none'; return; }

        matches.forEach(aparelho => {
            const item = document.createElement('section');
            item.className = 'eq-sugestao-item';
            item.textContent = aparelho.nome;
            item.onclick = () => selecionarAparelho(aparelho);
            sugestoesEl.appendChild(item);
        });
        sugestoesEl.style.display = 'block';
    });

    document.addEventListener('click', e => {
        if (!inputAparelho.contains(e.target) && !sugestoesEl.contains(e.target)) {
            sugestoesEl.style.display = 'none';
        }
    });
})();

async function selecionarAparelho(aparelho) {
    const inputAparelho = document.getElementById('eq-nome-input');
    const sugestoesEl   = document.getElementById('eq-nome-sugestoes');
    const exerciciosEl  = document.getElementById('eq-exercicios-preview');
    inputAparelho.value = aparelho.nome;
    sugestoesEl.style.display = 'none';
    exerciciosEl.innerHTML = '<p style="color:#888;font-size:.82rem"><i class="fas fa-spinner fa-spin"></i> Buscando exercícios...</p>';
    try {
        const params = new URLSearchParams();
        aparelho.equipment.forEach(eq => params.append('equipment', eq));
        const res  = await fetch(`/api/admin/equipamentos/exercicios?${params}`);
        const data = await res.json();
        renderizarExercicios(data.exercicios, aparelho);
    } catch (err) {
        exerciciosEl.innerHTML = '<p style="color:#e74c3c">Erro ao buscar exercícios.</p>';
    }
}

const BODY_PART_LABELS = {
    back: 'Costas', chest: 'Peito', shoulders: 'Ombro',
    'upper arms': 'Braço', 'lower arms': 'Antebraço',
    'upper legs': 'Perna', 'lower legs': 'Panturrilha',
    waist: 'Core / Abdômen', cardio: 'Cardio', outros: 'Outros',
};

function renderizarExercicios(exercicios, aparelho) {
    const exerciciosEl = document.getElementById('eq-exercicios-preview');
    if (!exercicios || !exercicios.length) {
        exerciciosEl.innerHTML = '<p style="color:#888;font-size:.82rem">Nenhum exercício encontrado.</p>';
        return;
    }
    const grupos = {};
    exercicios.forEach(ex => {
        const g = ex.body_part || 'outros';
        if (!grupos[g]) grupos[g] = [];
        grupos[g].push(ex);
    });
    let html = `
        <section class="eq-ex-header">
            <span>${exercicios.length} exercícios para <strong>${aparelho.nome}</strong></span>
            <section>
                <button type="button" onclick="toggleTodos(true)"  class="btn-eq-sm">Todos</button>
                <button type="button" onclick="toggleTodos(false)" class="btn-eq-sm btn-eq-sm-outline">Nenhum</button>
            </section>
        </section>
    `;
    Object.entries(grupos).forEach(([grupo, exs]) => {
        const grupoId = 'grp-' + grupo.replace(/\s+/g, '-');
        html += `
            <section class="eq-grupo-card">
                <section class="eq-grupo-header" onclick="toggleGrupo('${grupoId}')">
                    <span><i class="fas fa-chevron-down"></i> ${BODY_PART_LABELS[grupo] || grupo} (${exs.length})</span>
                    <section onclick="event.stopPropagation()">
                        <button type="button" onclick="toggleGrupoCheck('${grupoId}', true)"  class="btn-eq-sm">Todos</button>
                        <button type="button" onclick="toggleGrupoCheck('${grupoId}', false)" class="btn-eq-sm btn-eq-sm-outline">Nenhum</button>
                    </section>
                </section>
                <section class="eq-grupo-lista" id="${grupoId}">
                    ${exs.map(ex => `
                        <label class="eq-ex-item">
                            <input type="checkbox" name="exercise_ids[]" value="${ex.id}" checked>
                            <span class="eq-ex-nome">${ex.name_pt || ex.name}</span>
                            <span class="eq-ex-musculo">${ex.target_muscle || ''}</span>
                        </label>
                    `).join('')}
                </section>
            </section>
        `;
    });
    exerciciosEl.innerHTML = html;
}

function toggleTodos(marcar) {
    document.querySelectorAll('#eq-exercicios-preview input[type="checkbox"]')
        .forEach(cb => cb.checked = marcar);
}

function toggleGrupo(grupoId) {
    const lista = document.getElementById(grupoId);
    if (!lista) return;
    const isVisible = lista.style.display !== 'none';
    lista.style.display = isVisible ? 'none' : '';
    const header = lista.previousElementSibling;
    if (header) {
        const icon = header.querySelector('.fa-chevron-down');
        if (icon) icon.style.transform = isVisible ? 'rotate(-90deg)' : '';
    }
}

function toggleGrupoCheck(grupoId, marcar) {
    const lista = document.getElementById(grupoId);
    if (!lista) return;
    lista.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = marcar);
}

async function salvarNovoEquipamento() {
    const nome        = document.getElementById('eq-nome-input').value.trim();
    const grupo       = document.getElementById('eq-grupo-novo').value;
    const academia_id = document.getElementById('eq-academia-novo').value || null;
    if (!nome) { alert('Digite o nome do aparelho.'); return; }

    const checkboxes   = document.querySelectorAll('#eq-exercicios-preview input[type="checkbox"]:checked');
    const exercise_ids = [...checkboxes].map(cb => cb.value);

    const btn = document.getElementById('btnSalvarNovo');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Salvando...';
    try {
        const res  = await fetch('/api/admin/equipamentos', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ nome, grupo_muscular: grupo, academia_id, exercise_ids }),
        });
        const data = await res.json();
        if (res.ok) {
            fecharModal('modalNovoEquip');
            await carregarEquipamentos();
        } else {
            alert(data.erro || 'Erro ao salvar.');
        }
    } catch (err) {
        alert('Erro ao salvar equipamento.');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Salvar';
    }
}

