<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('../partials/seo') %>
<link rel="icon" type="image/x-icon" href="/images/favicon.ico">
<link rel="stylesheet" href="/css/header.css">
<link rel="stylesheet" href="/css/area-aluno.css">
<link rel="stylesheet" href="/css/ai-chat.css">
</head>
<body>

<%- include('../partials/header') %>

<section class="aluno-dashboard">
    <section class="sidebar-overlay" id="sidebarOverlay"></section>

    <!-- SIDEBAR -->
    <section class="aluno-sidebar">
        <section class="aluno-profile">
            <section class="avatar">
                <img id="sidebar-avatar" src="<%= user.profile_photo || '/images/avatar.png' %>" alt="Avatar do Aluno">
            </section>
            <h2><%= user.nome %></h2>
            <p data-translate="sidebar.role">Aluno GymBros</p>
        </section>
        <ul class="aluno-menu">
            <li><a href="/area-aluno" data-translate="sidebar.painel"><i class="fas fa-tachometer-alt"></i> Painel</a></li>
            <li><a href="/treinos" data-translate="sidebar.treinos"><i class="fas fa-dumbbell"></i> Meus Treinos</a></li>
            <li><a href="/evolucao" data-translate="sidebar.evolucao"><i class="fas fa-chart-line"></i> Evolução</a></li>
            <li><a href="/meu-plano" data-translate="sidebar.plano"><i class="fas fa-file-alt"></i> Meu Plano</a></li>
            <li><a href="/config" data-translate="sidebar.config"><i class="fas fa-cog"></i> Configurações</a></li>
            <% if (user && (user.planoSlug === 'gymbro' || user.planoSlug === 'black')) { %>
            <li><a href="/ai/chat" class="active" data-translate="sidebar.ai"><i class="fas fa-robot"></i> Personal Trainer IA</a></li>
            <li><a href="/ai/avaliacao" data-translate="sidebar.avaliacao"><i class="fas fa-camera"></i> Avaliação Corporal</a></li>
            <% } else { %>
            <li><a href="/meu-plano?upgrade=1" class="menu-locked" data-translate="sidebar.ai"><i class="fas fa-robot"></i> Personal Trainer IA 🔒</a></li>
            <li><a href="/meu-plano?upgrade=1" class="menu-locked" data-translate="sidebar.avaliacao"><i class="fas fa-camera"></i> Avaliação Corporal 🔒</a></li>
            <% } %>
            <li><a href="/imc-form" data-translate="sidebar.imc"><i class="fas fa-clipboard-list"></i> Meu Perfil IMC</a></li>
            <li><a href="/suporte" data-translate="sidebar.suporte"><i class="fas fa-headset"></i> Suporte</a></li>
        </ul>
    </section>

    <!-- CONTEÚDO PRINCIPAL -->
    <section class="aluno-main">
        <section class="dashboard-top">
            <h1><i class="fas fa-robot"></i> Personal Trainer IA</h1>
            <p>Tire suas dúvidas sobre treinos, exercícios, nutrição e muito mais</p>
        </section>

        <!-- ÁREA DO CHAT -->
        <section class="chat-container">

            <section class="chat-history" id="chatHistory">
                <!-- Mensagem de boas-vindas do bot -->
                <section class="chat-message bot-message">
                    <section class="chat-bubble">
                        <strong>GymBot</strong>
                        <p>Olá, <%= user.nome %>! 💪 Sou o GymBot, seu personal trainer virtual. Como posso te ajudar hoje? Pode me perguntar sobre treinos, exercícios, nutrição ou motivação!</p>
                    </section>
                </section>
            </section>

            <!-- INDICADOR DE DIGITANDO -->
            <section class="typing-indicator" id="typingIndicator" style="display: none;">
                <section class="chat-bubble">
                    <span class="dot"></span>
                    <span class="dot"></span>
                    <span class="dot"></span>
                </section>
            </section>

            <!-- INPUT -->
            <section class="chat-input-area">
                <input
                    type="text"
                    id="chatInput"
                    placeholder="Digite sua mensagem..."
                    autocomplete="off"
                    maxlength="500"
                />
                <button id="sendBtn" onclick="sendMessage()">
                    <i class="fas fa-paper-plane"></i> <span class="btn-label">Enviar</span>
                </button>
            </section>

        </section>

    </section>

</section>

<link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
<script>
    const chatHistory = document.getElementById('chatHistory');
    const chatInput = document.getElementById('chatInput');
    const sendBtn = document.getElementById('sendBtn');
    const typingIndicator = document.getElementById('typingIndicator');

    chatInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    function appendPlan(reply) {
        const wrapper = document.createElement('section');
        wrapper.classList.add('chat-message', 'bot-message');

        const bubble = document.createElement('section');
        bubble.classList.add('chat-bubble');

        const name = document.createElement('strong');
        name.textContent = 'GymBot';
        bubble.appendChild(name);

        const preview = document.createElement('section');
        preview.classList.add('plan-preview');

        if (reply.type === 'workout') {
            const plan = reply.plan || {};
            const title = document.createElement('h3');
            title.classList.add('plan-preview-title');
            title.textContent = plan.nome || '';
            preview.appendChild(title);
            (plan.exercicios || []).forEach(ex => {
                const row = document.createElement('section');
                row.classList.add('plan-row');
                row.innerHTML = `<strong>${ex.nome_pt}</strong> — ${ex.series}x ${ex.repeticoes} | Descanso: ${ex.descanso_segundos}s | Carga: ${ex.carga_sugerida}`;
                preview.appendChild(row);
            });
        } else {
            const plan = reply.plan || {};
            const title = document.createElement('h3');
            title.classList.add('plan-preview-title');
            title.textContent = plan.nome || '';
            preview.appendChild(title);
            const meta = document.createElement('p');
            meta.classList.add('plan-diet-meta');
            meta.textContent = `${plan.objetivo_calorico || 0} kcal/dia · Proteína: ${plan.proteina_diaria_g || 0}g`;
            preview.appendChild(meta);
            (plan.refeicoes || []).forEach(ref => {
                const block = document.createElement('section');
                block.classList.add('plan-row');
                const refTitle = document.createElement('strong');
                refTitle.textContent = `${ref.nome} (${ref.horario_sugerido})`;
                block.appendChild(refTitle);
                (ref.alimentos || []).forEach(al => {
                    const alEl = document.createElement('span');
                    alEl.classList.add('plan-alimento');
                    alEl.textContent = `${al.nome} ${al.quantidade} — ${al.kcal} kcal`;
                    block.appendChild(alEl);
                });
                preview.appendChild(block);
            });
        }

        bubble.appendChild(preview);

        const actions = document.createElement('section');
        actions.classList.add('plan-actions');

        const btnSave = document.createElement('button');
        btnSave.classList.add('plan-btn', 'plan-btn-confirm');
        btnSave.textContent = 'Confirmar e salvar';
        btnSave.onclick = async () => {
            btnSave.disabled = true;
            btnAlt.disabled = true;
            try {
                const res  = await fetch('/ai/plan/save', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ type: reply.type, plan: reply.plan })
                });
                const data = await res.json();
                if (!data.ok) {
                    btnSave.disabled = false;
                    btnAlt.disabled = false;
                    btnSave.textContent = data.error || 'Erro ao salvar';
                } else {
                    btnSave.textContent = 'Salvo!';
                }
            } catch {
                btnSave.disabled = false;
                btnAlt.disabled = false;
                btnSave.textContent = 'Erro ao salvar';
            }
        };

        const btnAlt = document.createElement('button');
        btnAlt.classList.add('plan-btn', 'plan-btn-alter');
        btnAlt.textContent = 'Quero alterar';
        btnAlt.onclick = () => {
            actions.remove();
            chatInput.value = 'quero alterar o plano';
            sendMessage();
        };

        actions.appendChild(btnSave);
        actions.appendChild(btnAlt);
        bubble.appendChild(actions);

        wrapper.appendChild(bubble);
        chatHistory.appendChild(wrapper);
        chatHistory.scrollTop = chatHistory.scrollHeight;
    }

    function appendMessage(text, sender) {
        const wrapper = document.createElement('section');
        wrapper.classList.add('chat-message', sender === 'user' ? 'user-message' : 'bot-message');

        const bubble = document.createElement('section');
        bubble.classList.add('chat-bubble');

        if (sender === 'bot') {
            const name = document.createElement('strong');
            name.textContent = 'GymBot';
            bubble.appendChild(name);
        }

        const p = document.createElement('p');
        p.textContent = text;
        bubble.appendChild(p);

        wrapper.appendChild(bubble);
        chatHistory.appendChild(wrapper);
        chatHistory.scrollTop = chatHistory.scrollHeight;
    }

    async function sendMessage() {
        const message = chatInput.value.trim();
        if (!message) return;

        chatInput.value = '';
        sendBtn.disabled = true;
        chatInput.disabled = true;

        appendMessage(message, 'user');

        typingIndicator.style.display = 'flex';
        chatHistory.scrollTop = chatHistory.scrollHeight;

        try {
            const response = await fetch('/ai/message', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message })
            });
            const data = await response.json();
            typingIndicator.style.display = 'none';
            if (data.reply && (data.reply.type === 'workout' || data.reply.type === 'diet')) {
                appendPlan(data.reply);
            } else {
                const botText = typeof data.reply === 'object' ? data.reply.message : data.reply;
                appendMessage(botText, 'bot');
            }
        } catch (err) {
            typingIndicator.style.display = 'none';
            appendMessage('Desculpe, não consegui processar sua mensagem. Tente novamente.', 'bot');
        } finally {
            sendBtn.disabled = false;
            chatInput.disabled = false;
            chatInput.focus();
        }
    }
</script>

<script>
(function () {
    var btn     = document.getElementById('menuToggle');
    var sidebar = document.querySelector('.aluno-sidebar');
    var overlay = document.getElementById('sidebarOverlay');
    if (!btn || !sidebar || !overlay) return;
    function openMenu()  { sidebar.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeMenu() { sidebar.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow = ''; }
    btn.addEventListener('click', openMenu);
    overlay.addEventListener('click', closeMenu);
    sidebar.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', closeMenu); });
})();
</script>
</body>
</html>
