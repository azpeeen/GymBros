<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('../partials/seo') %>
<link rel="icon" type="image/x-icon" href="/images/favicon.ico">
<link rel="stylesheet" href="/css/header.css">
<link rel="stylesheet" href="/css/footer.css">
<link rel="stylesheet" href="/css/area-aluno.css">
<link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
</head>
<body>

<%- include('../partials/header') %>

<section class="aluno-dashboard">
    <section class="sidebar-overlay" id="sidebarOverlay"></section>

    <!-- SIDEBAR -->
    <section class="aluno-sidebar">
        <section class="aluno-profile">
            <section class="avatar">
                <img src="<%= user.profile_photo || '/images/avatar.png' %>" alt="Avatar do Aluno">
            </section>
            <h2><%= user.nome %></h2>
            <p data-translate="sidebar.role">Aluno GymBros</p>
        </section>
        <ul class="aluno-menu">
            <li><a href="/area-aluno" data-translate="sidebar.painel"><i class="fas fa-tachometer-alt"></i> Painel</a></li>
            <li><a href="/treinos" data-translate="sidebar.treinos"><i class="fas fa-dumbbell"></i> Meus Treinos</a></li>
            <li><a href="/evolucao" data-translate="sidebar.evolucao"><i class="fas fa-chart-line"></i> Evolução</a></li>
            <% if (user && (user.planoSlug === 'gymbro' || user.planoSlug === 'black')) { %>
            <li><a href="/ai/chat" data-translate="sidebar.ai"><i class="fas fa-robot"></i> Personal Trainer IA</a></li>
            <li><a href="/ai/avaliacao" data-translate="sidebar.avaliacao"><i class="fas fa-camera"></i> Avaliação Corporal</a></li>
            <% } else { %>
            <li><a href="/meu-plano?upgrade=1" class="menu-locked" data-translate="sidebar.ai"><i class="fas fa-robot"></i> Personal Trainer IA 🔒</a></li>
            <li><a href="/meu-plano?upgrade=1" class="menu-locked" data-translate="sidebar.avaliacao"><i class="fas fa-camera"></i> Avaliação Corporal 🔒</a></li>
            <% } %>
            <li><a href="/imc-form" data-translate="sidebar.imc"><i class="fas fa-clipboard-list"></i> Meu Perfil IMC</a></li>
            <li><a href="/perfil/<%= user.id %>"><i class="fas fa-user-circle"></i> Meu Perfil</a></li>
            <li><a href="/conquistas" data-translate="sidebar.conquistas"><i class="fas fa-trophy"></i> Conquistas</a></li>
            <li><a href="/meu-plano" class="active" data-translate="sidebar.plano"><i class="fas fa-file-alt"></i> Meu Plano</a></li>
            <li><a href="/suporte" data-translate="sidebar.suporte"><i class="fas fa-headset"></i> Suporte</a></li>
            <li><a href="/config" data-translate="sidebar.config"><i class="fas fa-cog"></i> Configurações</a></li>
        </ul>
    </section>

    <!-- CONTEÚDO PRINCIPAL -->
    <section class="aluno-main">
        <section class="dashboard-top">
            <h1 data-i18n="myplan.title">Meu Plano</h1>
            <p data-i18n="myplan.subtitle">Gerencie sua assinatura, veja benefícios e compare com outros planos.</p>
        </section>

        <!-- PLANO ATUAL -->
        <section class="plano-atual-card">

            <section class="plano-atual-top">
                <section>
                    <section class="plano-atual-nome">
                        <i class="fas fa-crown"></i> <%= planoAtual.nome %>
                    </section>
                    <section class="plano-atual-desc"><%= planoAtual.descricao %></section>
                </section>
                <section>
                    <section class="plano-atual-preco">
                        <%= planoAtual.preco %>
                        <small>/<%= planoAtual.periodo %></small>
                    </section>
                    <span class="plano-atual-badge">
                        <i class="fas fa-check-circle"></i> <span data-i18n="myplan.active">Plano ativo</span>
                    </span>
                </section>
            </section>

            <!-- Benefícios -->
            <section class="plano-beneficios">
                <% (planoAtual.beneficios || []).forEach(b => { %>
                <section class="plano-beneficio-item">
                    <i class="fas fa-check-circle"></i>
                    <span><%= b %></span>
                </section>
                <% }) %>
            </section>

            <!-- Barra de renovação -->
            <section class="plano-renew">
                <section class="plano-renew-labels">
                    <span><i class="fas fa-calendar-alt"></i> Renovação em <%= planoAtual.renovacao %></span>
                    <span><%= planoAtual.tempoRestanteDias %> dias restantes</span>
                </section>
                <section class="plano-renew-bar">
                    <section class="plano-renew-fill" id="renew-fill"></section>
                </section>
                <section class="plano-renew-note" data-i18n="myplan.renew">Seu plano renova automaticamente na data acima.</section>
            </section>

            <!-- Ações -->
            <section class="plano-acoes">
                <a href="/planos" class="plano-btn plano-btn-cancelar">
                    <i class="fas fa-times-circle"></i> Cancelar Plano
                </a>
                <a href="/planos" class="plano-btn plano-btn-upgrade">
                    <i class="fas fa-rocket"></i> Fazer Upgrade
                </a>
            </section>

        </section>

        <!-- OUTROS PLANOS -->
        <section class="outros-planos-titulo">
            <i class="fas fa-exchange-alt"></i> <span data-i18n="myplan.others">Outros Planos Disponíveis</span>
        </section>

        <section class="outros-planos-grid">
            <% outrosPlanos.forEach(plano => { %>
            <section class="plano-card <%= plano.destaque ? 'plano-card-destaque' : '' %>">

                <% if (plano.destaque) { %>
                <span class="plano-card-ribbon"><i class="fas fa-fire"></i> Mais completo</span>
                <% } %>

                <section class="plano-card-nome"><%= plano.nome %></section>
                <section class="plano-card-desc"><%= plano.descricao %></section>

                <section class="plano-card-preco">
                    <%= plano.preco %>
                    <small>/<%= plano.periodo %></small>
                </section>

                <ul class="plano-card-lista">
                    <% (plano.beneficios || []).forEach(b => { %>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span><%= b %></span>
                    </li>
                    <% }) %>
                </ul>

                <a href="/planos" class="plano-card-btn">
                    <i class="fas fa-arrow-right"></i> Assinar <%= plano.nome %>
                </a>

            </section>
            <% }) %>
        </section>

    </section>
</section>

<%- include('../partials/footer') %>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var fill = document.getElementById('renew-fill');
    if (fill) {
        requestAnimationFrame(function () {
            fill.style.width = '<%= planoAtual.progresso %>%';
        });
    }
});

(function () {
    var btn     = document.getElementById('menuToggle');
    var sidebar = document.querySelector('.aluno-sidebar');
    var overlay = document.getElementById('sidebarOverlay');
    if (!btn || !sidebar || !overlay) return;
    function openMenu()  { sidebar.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeMenu() { sidebar.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow = ''; }
    btn.addEventListener('click', openMenu);
    overlay.addEventListener('click', closeMenu);
    sidebar.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', closeMenu); });
})();
</script>
</body>
</html>
